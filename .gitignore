# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files — never commit real secrets
.env
.env.*
!.env.example

# Large build artifacts / nested archives
*.zip

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Playwright e2e seeded fixture (machine-local)
e2e/.seed.json
e2e/test-results/
playwright-report/

# Bun-only project — ignore other package-manager lockfiles
package-lock.json
yarn.lock
pnpm-lock.yaml