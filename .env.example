# Public browser configuration injected by Vite.
#
# Values prefixed with VITE_ are bundled into client-side JavaScript. Never put
# service-role keys, webhook secrets, Stripe secret keys, or other private
# credentials in this file or behind a VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Optional independent HTTPS collector for bootstrap/client errors. This must
# not depend on Supabase, must accept credential-free JSON POST requests, and
# its exact origin must be allowlisted in public/_headers (the default policy
# includes https://errors.crownmemedia.com).
VITE_ERROR_REPORTING_ENDPOINT=
VITE_APP_RELEASE=

# Lovable Payments injects the appropriate publishable key in hosted builds.
# For local development, use only a Stripe publishable key (pk_test_...).
VITE_PAYMENTS_CLIENT_TOKEN=
